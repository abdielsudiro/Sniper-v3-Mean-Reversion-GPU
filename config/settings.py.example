import os

# --- Path Configuration ---
PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
BASE_DATA_PATH = os.path.join(PROJECT_ROOT, 'data/processed/eurusd_m1.parquet')
MODEL_SAVE_PATH = os.path.join(PROJECT_ROOT, 'models/MREV_1MIN_v1.json')

# --- Strategy Parameters (standard/public values) ---
Z_THRESHOLD = 2.0          # Standard statistical threshold
WINDOW_SIZE = 20           # Number of bars used to compute the rolling mean
ML_PROB_LIMIT = 0.50       # Minimum model confidence required (50%)

# --- Risk Management (template values) ---
ATR_TP_MULT = 1.0          # Take Profit multiplier
ATR_SL_MULT = 1.0          # Stop Loss multiplier
HOLD_BARS = 5              # Maximum holding period (bars)
SPREAD_COST = 0.00010      # Approximate spread cost (1 pip)

# --- XGBoost Hyperparameters (default values, not yet optimized) ---
XGB_N_ESTIMATORS = 100
XGB_MAX_DEPTH = 3
XGB_LEARNING_RATE = 0.1
XGB_DEVICE = 'cuda'        # Use 'cpu' if no GPU is available
