# Sniper v3.0 - Strategy Parameters
# Copy to .env and tune, or run scripts/04_optimize_v1.0.py to auto-fill.

# --- Paths ---
BASE_DATA_PATH=data/processed/eurusd_m1.parquet
MODEL_SAVE_PATH=models/1MIN/MREV_1MIN_v1.json

# --- Strategy ---
Z_THRESHOLD=2.0
WINDOW_SIZE=20
ML_PROB_LIMIT=0.50       # 1MIN model: P(short wins) > this threshold
ML_PROB_LIMIT_5M=0.50    # 5MIN model: same directional logic (default = ML_PROB_LIMIT)

# --- Risk Management ---
ATR_TP_MULT=1.0
ATR_SL_MULT=1.0
HOLD_BARS=5
SPREAD_COST=0.0001
BREAKEVEN_MULT=0.0       # 0=disabled; N=move SL to entry once unrealized PnL >= N*ATR

# --- XGBoost ---
XGB_N_ESTIMATORS=100
XGB_MAX_DEPTH=3
XGB_LEARNING_RATE=0.1
XGB_DEVICE=cpu

# --- MT5 Live Trading ---
MT5_LOGIN=12345678          # your MT5 account number
MT5_PASSWORD=your_password
MT5_SERVER=YourBroker-Server
MT5_SYMBOL=EURUSD           # exact symbol name in your broker (e.g. EURUSDm)
MT5_LOT=0.01                # lot size per trade
MT5_MAGIC=203001            # unique int to tag Sniper orders vs manual trades
MT5_PATH=                   # optional: full path to terminal64.exe

# --- Enhanced Backtest Flags (03_backtest_v1.0.py / 04_optimize_v1.0.py) ---
SESSION_FILTER=true      # trade only London + NY sessions (UTC 07-21)
DYNAMIC_SPREAD=true      # session-aware spread (london_ny=0.3pip, asian=1.5pip)
MTF_CONFIRM=true         # require 5MIN model to confirm 1MIN signal direction
MTF_MODEL_PATH=models/5MIN/MREV_5MIN_v1.json
